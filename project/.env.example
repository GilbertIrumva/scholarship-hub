MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=scholarshipzone
PORT=3000

# ---- Optional: SMTP for outbound admin replies -----------------------------
# If unset, replies are saved to the database AND logged to the server console
# (LOG mode). Once you provide these vars, the same reply button sends real email.
#
# Gmail example (use an App Password, NOT your account password):
#   1. Enable 2-Step Verification on the account
#   2. Visit https://myaccount.google.com/apppasswords and create one for "Mail"
#   3. Paste the 16-char password into SMTP_PASS below
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# MAIL_FROM=ScholarshipZone <yourname@gmail.com>

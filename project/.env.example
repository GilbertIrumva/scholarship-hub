MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=scholarshipzone
PORT=3000

# ---- Production hardening --------------------------------------------------
# NODE_ENV: set to "production" on real deployments. Triggers JSON logs,
# stricter error responses, and refuses to boot if TRAVEL_DOC_SECRET is unset.
# NODE_ENV=production

# CORS_ORIGINS: comma-separated list of allowed front-end origins.
# REQUIRED in production. In development, leaving it blank allows any origin.
# CORS_ORIGINS=https://app.scholarshipzone.com,https://admin.scholarshipzone.com

# TRAVEL_DOC_SECRET: 32+ char random string used to derive the AES-256-GCM key
# that encrypts passport/visa numbers at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# TRAVEL_DOC_SECRET=replace-me-with-a-long-random-string

# LOG_LEVEL: pino log level — trace | debug | info | warn | error | fatal
# Defaults to "info" in production and "debug" in development.
# LOG_LEVEL=info

# ---- Optional: SMTP for outbound admin replies -----------------------------
# If unset, replies are saved to the database AND logged to the server console
# (LOG mode). Once you provide these vars, the same reply button sends real email.
#
# Gmail example (use an App Password, NOT your account password):
#   1. Enable 2-Step Verification on the account
#   2. Visit https://myaccount.google.com/apppasswords and create one for "Mail"
#   3. Paste the 16-char password into SMTP_PASS below
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# MAIL_FROM=ScholarshipZone <yourname@gmail.com>

# ---- Optional: Google OAuth (scholar sign-in / sign-up) --------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized redirect URIs: must EXACTLY match GOOGLE_REDIRECT_URI below
# If any of these four vars is missing, /api/auth/google/start returns 503 and
# the "Continue with Google" button does nothing dangerous.
#
# GOOGLE_CLIENT_ID=xxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_REDIRECT_URI=https://api.scholarshipzone.app/api/auth/google/callback
#
# OAUTH_STATE_SECRET: 32+ char random string used to HMAC-sign the OAuth state
# envelope so the callback can detect tampering / replays without server-side
# session storage. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# OAUTH_STATE_SECRET=replace-me-with-a-long-random-string
#
# APP_BASE_URL: public origin of the SPA. The OAuth callback redirects users
# to ${APP_BASE_URL}/auth/google?token=... — defaults to http://localhost:5173.
# APP_BASE_URL=https://app.scholarshipzone.app

# ---- Optional: S3 / R2 file storage (T3.1) --------------------------------
# Uploaded credentials and travel documents are written via the storage
# abstraction in lib/storage.js. The default is local disk under uploads/.
# Set STORAGE_BACKEND=s3 AND populate the vars below to push new uploads to
# an S3-compatible bucket (AWS S3 or Cloudflare R2). Existing records keep
# resolving through their original backend, so the switch is non-destructive.
#
# STORAGE_BACKEND=s3
# S3_BUCKET=scholarshipzone-prod
# S3_REGION=auto                          # 'auto' is correct for Cloudflare R2
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com   # omit for AWS S3
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
